PORT=3000
DATA_DIR=./data
LEVEL_PATH=./data/db

# Auth
JWT_SECRET=
JWT_EXPIRY=7d

# Credits
CREDIT_USD_VALUE=0.001
RATE_GB_HOUR=5

# Balance lifecycle
GRACE_PERIOD_DAYS=3
DELETE_AFTER_DAYS=7

# Litecoin node
LTC_RPC_HOST=127.0.0.1
LTC_RPC_PORT=9332
LTC_RPC_USER=
LTC_RPC_PASS=
LTC_CONFIRMATIONS=6

# Bitcoin node
BTC_RPC_HOST=127.0.0.1
BTC_RPC_PORT=8332
BTC_RPC_USER=
BTC_RPC_PASS=
BTC_CONFIRMATIONS=6

# Dogecoin node
DOGE_RPC_HOST=127.0.0.1
DOGE_RPC_PORT=22555
DOGE_RPC_USER=
DOGE_RPC_PASS=
DOGE_CONFIRMATIONS=6

# Zcash node (transparent addresses only)
ZEC_RPC_HOST=127.0.0.1
ZEC_RPC_PORT=8232
ZEC_RPC_USER=
ZEC_RPC_PASS=
ZEC_CONFIRMATIONS=10

# Monero wallet RPC
XMR_RPC_HOST=127.0.0.1
XMR_RPC_PORT=18083
XMR_CONFIRMATIONS=10
XMR_WALLET_ACCOUNT=0

# Chain poller
CHAIN_POLL_INTERVAL_MS=60000

# Accepted currencies
ACCEPTED_CURRENCIES=ltc,xmr

# CORS — set to decentral.ninja origin in production
CORS_ORIGIN=https://decentral.ninja

# File upload size limit (MB)
MAX_FILE_SIZE_MB=500
